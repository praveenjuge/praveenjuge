---
import Layout from "../Layout.astro";
import { AUTHOR } from "../consts";
---

<Layout title="My Social Links">
  <section class="mx-auto max-w-xl space-y-4 px-4">
    <h2 class="font-semibold">Links</h2>
    <ul
      class="flex flex-col gap-2 font-medium [&_a]:p-4 [&_a]:rounded [&_a]:border [&_a]:border-gray-200"
    >
      <li>
        <a class="flex justify-between items-center" href={AUTHOR.social.x}
          >X (Twitter) <svg
            role="presentation"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            stroke-linecap="round"
            stroke-linejoin="round"
            xmlns="http://www.w3.org/2000/svg"
            class="shrink-0"><path d="m6.5 17.5 11-11m0 0h-9m9 0v9"></path></svg
          ></a
        >
      </li>
      <li>
        <a class="flex justify-between items-center" href={AUTHOR.social.figma}
